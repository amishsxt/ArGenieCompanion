<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state — strong white+blue glow for Vuzix D-pad -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#EDF6FF" />
            <corners android:radius="14dp" />
            <stroke
                android:width="3dp"
                android:color="#33B5E5" />
        </shape>
    </item>

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#D0EDFA" />
            <corners android:radius="14dp" />
            <stroke
                android:width="2dp"
                android:color="#1A8FC7" />
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorSurface" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/neutral_100" />
        </shape>
    </item>

</selector>
