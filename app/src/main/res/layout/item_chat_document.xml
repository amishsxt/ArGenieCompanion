<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <LinearLayout
        android:id="@+id/message_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:maxWidth="300dp">

        <!-- Sender row: avatar + name (hidden for user messages) -->
        <LinearLayout
            android:id="@+id/sender_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/avatar_iv"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_baseline_person_24"
                android:background="@drawable/bg_avatar_circle"
                android:padding="4dp"
                android:contentDescription="Avatar" />

            <TextView
                android:id="@+id/sender_name_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="11sp"
                android:textColor="?colorOnSurfaceVariant"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Document bubble — focusable and clickable for Vuzix D-pad -->
        <LinearLayout
            android:id="@+id/doc_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="28dp"
            android:minHeight="72dp"
            android:background="@drawable/bg_doc_bubble_selector"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp"
            android:orientation="vertical"
            android:focusable="true"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants">

            <!-- Top row: icon + file info -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- File icon -->
                <ImageView
                    android:id="@+id/file_icon_iv"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/docs_24px"
                    android:contentDescription="File" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/file_name_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/neutral_900"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:maxWidth="180dp" />

                    <TextView
                        android:id="@+id/file_type_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="11sp"
                        android:textColor="@color/neutral_500" />

                </LinearLayout>

            </LinearLayout>

            <!-- Open indicator row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to Open"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/arrow_back_ios_24px"
                    android:rotation="180"
                    android:contentDescription="Open"
                    app:tint="@color/colorPrimary"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
