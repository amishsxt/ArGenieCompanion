<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Image viewer -->
    <me.relex.photodraweeview.PhotoDraweeView
        android:id="@+id/doc_viewer_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- PDF viewer -->
    <com.example.argeniecompanion.ui.PdfViewportView
        android:id="@+id/doc_viewer_pdf"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Unsupported / other file type -->
    <LinearLayout
        android:id="@+id/doc_viewer_other"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/doc_viewer_file_icon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/docs_24px"
            app:tint="#AAAAAA" />

        <TextView
            android:id="@+id/doc_viewer_file_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/doc_viewer_mime_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

        <Button
            android:id="@+id/doc_viewer_open_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Open with…"
            android:focusable="true"
            android:focusableInTouchMode="true" />

    </LinearLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/doc_viewer_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:indeterminateTint="#FFFFFF" />

    </FrameLayout>

    <!-- Top bar (always on top) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/doc_viewer_back_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:src="@drawable/arrow_back_ios_24px"
            app:tint="#FFFFFF"
            android:contentDescription="Back"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:background="@drawable/focus_back_selector" />

        <TextView
            android:id="@+id/doc_viewer_title"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:singleLine="true"
            android:ellipsize="middle" />

        <TextView
            android:id="@+id/doc_viewer_page_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
