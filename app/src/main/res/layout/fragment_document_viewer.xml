<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="#CC000000">

        <!-- Close button — large touch target for Vuzix -->
        <ImageView
            android:id="@+id/viewer_close_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:src="@drawable/arrow_back_ios_24px"
            app:tint="@color/white"
            android:contentDescription="Close"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/focus_back_selector" />

        <TextView
            android:id="@+id/viewer_file_name_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/viewer_file_type_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="#33FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

    <!-- PDF WebView -->
    <WebView
        android:id="@+id/viewer_webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Image viewer (Fresco zoomable) -->
    <me.relex.photodraweeview.PhotoDraweeView
        android:id="@+id/viewer_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Other file info screen -->
    <LinearLayout
        android:id="@+id/viewer_file_info"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/viewer_file_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/docs_24px"
            app:tint="@color/white"
            android:contentDescription="File icon" />

        <TextView
            android:id="@+id/viewer_info_name_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="middle" />

        <TextView
            android:id="@+id/viewer_info_mime_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:textColor="@color/neutral_300"
            android:gravity="center" />

        <TextView
            android:id="@+id/viewer_open_external_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Open in App"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingHorizontal="32dp"
            android:paddingVertical="14dp"
            android:background="@drawable/focus_button_selector"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Open in external app" />

    </LinearLayout>

    <!-- Loading indicator -->
    <FrameLayout
        android:id="@+id/viewer_loading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="80dp"
            android:text="Loading…"
            android:textSize="14sp"
            android:textColor="@color/neutral_300" />

    </FrameLayout>

</LinearLayout>
