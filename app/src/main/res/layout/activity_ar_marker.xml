<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="?colorSurfaceVariant">

        <ImageView
            android:id="@+id/back_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/arrow_back_ios_24px"
            app:tint="?colorOnSurface"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/focus_back_selector"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="AR Marker Annotation"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?colorOnSurface"
            android:singleLine="true"
            android:ellipsize="end"
            android:focusable="false" />

        <!-- Status indicator shown while detecting -->
        <TextView
            android:id="@+id/detection_status_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Searching…"
            android:textSize="12sp"
            android:textColor="@android:color/holo_orange_light"
            android:focusable="false" />

    </LinearLayout>

    <!-- Camera + annotation layers stacked in a FrameLayout -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- GL layer: camera preview background -->
        <android.opengl.GLSurfaceView
            android:id="@+id/gl_surface_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Canvas layer: annotation overlays drawn on top -->
        <com.example.argeniecompanion.ui.AnnotationOverlayView
            android:id="@+id/annotation_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

</LinearLayout>
