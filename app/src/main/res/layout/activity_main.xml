<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?colorSurfaceVariant"
        android:descendantFocusability="afterDescendants">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <ImageView
                android:id="@+id/back_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/arrow_back_ios_24px"
                app:tint="?colorOnSurface"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/focus_back_selector"
                android:nextFocusDown="@id/start_server_btn"
                android:nextFocusUp="@id/start_server_btn"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?colorOnSurface"
                android:singleLine="true"
                android:ellipsize="end"
                android:focusable="false"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/white_board_iv"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/draw_24px"
                app:tint="?colorOnSurface"
                android:contentDescription="Whiteboard"
                android:visibility="gone"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/focus_back_selector" />

            <ImageView
                android:id="@+id/documents_iv"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/docs_24px"
                app:tint="?colorOnSurface"
                android:contentDescription="Documents"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/focus_back_selector" />

            <ImageView
                android:id="@+id/chat_iv"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/chat_icon"
                app:tint="?colorOnSurface"
                android:contentDescription="Chat"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/focus_back_selector" />
        </LinearLayout>

        <TextView
            android:id="@+id/status_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Not Running"
            android:textSize="16sp"
            android:textColor="@android:color/holo_orange_dark"
            android:paddingBottom="8dp"
            android:gravity="center"
            android:focusable="false" />

        <LinearLayout
            android:id="@+id/device_status_lly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/link_code_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_blue_dark"
                android:paddingBottom="16dp"
                android:gravity="center"
                android:focusable="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="15dp">

                <ImageView
                    android:id="@+id/camera_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/videocam_off_24px"
                    app:tint="@color/white"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="8dp"
                    android:backgroundTint="@color/colorPrimary"
                    android:focusable="false"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp"
                    android:focusable="false"/>

                <ImageView
                    android:id="@+id/mic_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/mic_off_24px"
                    app:tint="@color/white"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="8dp"
                    android:backgroundTint="@color/colorPrimary"
                    android:focusable="false"/>

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/start_server_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Server"
            android:textColor="@android:color/white"
            android:background="@drawable/focus_button_green"
            app:backgroundTint="@null"
            android:layout_marginBottom="16dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/back_btn"
            android:nextFocusDown="@id/back_btn" />

        <Button
            android:id="@+id/stop_server_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop Server"
            android:textColor="@android:color/white"
            android:background="@drawable/focus_button_red"
            app:backgroundTint="@null"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/back_btn"
            android:nextFocusDown="@id/back_btn" />

        <LinearLayout
            android:id="@+id/call_controls_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/mic_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mic_on"
                    android:focusable="false" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp"/>

                <Button
                    android:id="@+id/camera_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/camera_on"
                    android:focusable="false" />
            </LinearLayout>

            <Button
                android:id="@+id/leave_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/leave_call"
                android:textColor="@android:color/white"
                android:backgroundTint="@android:color/holo_red_dark"
                android:focusable="false" />

        </LinearLayout>

        <!-- Message preview: shown temporarily when a chat message arrives during a call -->
        <LinearLayout
            android:id="@+id/message_preview_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="#EE1A237E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp"
            android:visibility="gone"
            android:focusable="false">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NEW MESSAGE"
                android:textSize="10sp"
                android:textColor="#B3FFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="3dp"
                android:focusable="false" />

            <TextView
                android:id="@+id/message_preview_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:focusable="false" />

            <TextView
                android:id="@+id/message_preview_time_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textSize="11sp"
                android:textColor="#80FFFFFF"
                android:focusable="false" />

        </LinearLayout>

        <!-- Debug log (hidden on device, kept for reference) -->
        <ScrollView
            android:id="@+id/message_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"
            android:focusable="false">

            <TextView
                android:id="@+id/message_log_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false" />
        </ScrollView>

    </LinearLayout>

    <!-- Fragment container overlays the main UI when a fragment is shown -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
